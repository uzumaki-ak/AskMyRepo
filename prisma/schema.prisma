generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["postgresqlExtensions"]
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")

    extensions = [vector]
}

model User {
    id               String            @id @default(cuid())
    createdAt        DateTime          @default(now())
    updatedAt        DateTime          @updatedAt
    imageUrl         String?
    firstName        String?
    lastName         String?
    emailAddress     String?           @unique
    credits          Int               @default(3000)
    preferredProvider String?
    userToProjects   UserToProject[]
    savedQuestions   SavedQuestion[]
    apiKeys          UserApiKey[]
    generatedReadmes GeneratedReadme[]
    mermaidDiagrams  MermaidDiagram[]
    interviewSets    InterviewQuestionSet[]
    audits           ProjectAudit[]
    dailyBriefs      DailyBrief[]
    aiChanges        AiChange[]
    interviewChats   InterviewChat[]
    knowledgeNotes   KnowledgeNote[]
}

model Project {
    id                   String                @id @default(cuid())
    createdAt            DateTime              @default(now())
    updatedAt            DateTime              @updatedAt
    name                 String
    githubUrl            String
    deletedAt            DateTime?
    embeddingStatus      String                @default("idle")
    embeddingTotal       Int                   @default(0)
    embeddingIndexed     Int                   @default(0)
    embeddingLastError   String?
    embeddingLastAttemptAt DateTime?
    embeddingRetryCount  Int                   @default(0)
    userToProjects       UserToProject[]
    commits              Commit[]
    sourceCodeEmbeddings SourceCodeEmbedding[]
    savedQuestions       SavedQuestion[]
    generatedReadmes     GeneratedReadme[]
    mermaidDiagrams      MermaidDiagram[]
    interviewSets        InterviewQuestionSet[]
    audits               ProjectAudit[]
    dailyBriefs          DailyBrief[]
    aiChanges            AiChange[]
    interviewChats       InterviewChat[]
    knowledgeNotes       KnowledgeNote[]
    invitations          Invitation[]
}

model AiChange {
    id            String   @id @default(cuid())
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    projectId     String
    userId        String
    fileName      String
    oldCode       String
    newCode       String
    prompt        String
    commitMessage String
    commitUrl     String?
    project       Project  @relation(fields: [projectId], references: [id])
    user          User     @relation(fields: [userId], references: [id])

    @@index([projectId])
}

enum Role {
    ADMIN
    MEMBER
}

model UserToProject {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    userId    String
    projectId String
    role      Role     @default(MEMBER)
    user      User     @relation(fields: [userId], references: [id])
    project   Project  @relation(fields: [projectId], references: [id])

    @@unique([userId, projectId])
}

model Invitation {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    email     String
    projectId String
    role      Role     @default(MEMBER)
    token     String   @unique
    expiresAt DateTime
    project   Project  @relation(fields: [projectId], references: [id])

    @@unique([email, projectId])
}

model KnowledgeNote {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    content   String
    userId    String
    projectId String
    user      User     @relation(fields: [userId], references: [id])
    project   Project  @relation(fields: [projectId], references: [id])
}

model SourceCodeEmbedding {
    id               String                 @id @default(cuid())
    summaryEmbedding Unsupported("vector")?
    sourceCode       String
    fileName         String
    summary          String
    projectId        String
    project          Project                @relation(fields: [projectId], references: [id])
}

model Commit {
    id                 String   @id @default(cuid())
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt
    projectId          String
    commitMessage      String
    commitHash         String
    commitAuthorName   String
    commitAuthorAvatar String
    commitDate         DateTime
    summary            String
    project            Project  @relation(fields: [projectId], references: [id])
}

model SavedQuestion {
    id             String   @id @default(cuid())
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
    userId         String
    projectId      String
    question       String
    answer         String
    fileReferences Json
    user           User     @relation(fields: [userId], references: [id])
    project        Project  @relation(fields: [projectId], references: [id])
}

// User API Keys for multiple LLM providers
model UserApiKey {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    userId    String
    provider  String // "groq", "google", "euron", "openrouter", "mistral", "openai"
    apiKey    String // Encrypted API key
    isActive  Boolean  @default(true)
    user      User     @relation(fields: [userId], references: [id])

    @@unique([userId, provider])
}

model InterviewChat {
    id         String   @id @default(cuid())
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
    userId     String
    projectId  String
    question   String
    answer     String
    messages   Json     // [{ role: 'user' | 'assistant', content: string }]
    user       User     @relation(fields: [userId], references: [id])
    project    Project  @relation(fields: [projectId], references: [id])

    @@index([projectId])
}

// Generated READMEs for projects
model GeneratedReadme {
    id             String   @id @default(cuid())
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
    userId         String
    projectId      String
    content        String // The generated README markdown content
    prompt         String? // Custom prompt used for generation
    includeMermaid Boolean  @default(false) // Whether to include mermaid diagrams
    model          String? // Which model was used for generation
    user           User     @relation(fields: [userId], references: [id])
    project        Project  @relation(fields: [projectId], references: [id])

    @@unique([userId, projectId])
}

model MermaidDiagram {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    userId    String
    projectId String
    chart     String   // The Mermaid diagram code
    prompt    String?  // Custom prompt used
    diagramType String // architecture, flow, etc.
    user      User     @relation(fields: [userId], references: [id])
    project   Project  @relation(fields: [projectId], references: [id])

    @@index([projectId])
}

model InterviewQuestionSet {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    userId    String
    projectId String
    questions Json     // Array of strings
    user      User     @relation(fields: [userId], references: [id])
    project   Project  @relation(fields: [projectId], references: [id])

    @@index([projectId])
}

model ProjectAudit {
    id              String   @id @default(cuid())
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt
    userId          String
    projectId       String
    complexity      Int
    documentation   Int
    modernity       Int
    maintainability Int
    summary         String
    user            User     @relation(fields: [userId], references: [id])
    project         Project  @relation(fields: [projectId], references: [id])

    @@index([projectId])
}

model DailyBrief {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    userId    String
    projectId String
    script    String   // The podcast script
    date      String   // Display date
    user      User     @relation(fields: [userId], references: [id])
    project   Project  @relation(fields: [projectId], references: [id])

    @@index([projectId])
}
